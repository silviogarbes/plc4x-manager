# ─── InfluxDB connection pool ──────────────────────────────────
_influx_client = None
_influx_client_lock = threading.Lock()

# ─── Update/rollback concurrency lock ─────────────────────────
_update_lock = threading.Lock()

def _get_influx_client():
    global _influx_client
    if _influx_client is None:
        with _influx_client_lock:
            if _influx_client is None:
                from influxdb_client import InfluxDBClient
                url = os.environ.get("INFLUXDB_URL", "http://influxdb:8086")
                token = os.environ.get("INFLUXDB_TOKEN", "plc4x-token")
                org = os.environ.get("INFLUXDB_ORG", "plc4x")
                _influx_client = InfluxDBClient(url=url, token=token, org=org, timeout=30_000, enable_gzip=True)
    return _influx_client


# ─── Tag history cache (avoid repeated identical queries) ──────
_trend_cache = {}
_trend_cache_lock = threading.Lock()
_TREND_CACHE_TTL = 5  # seconds
_TREND_CACHE_MAX = 100  # max cached queries

def _trend_cache_get(key):
    with _trend_cache_lock:
        entry = _trend_cache.get(key)
        if entry and (time.time() - entry[0]) < _TREND_CACHE_TTL:
            return entry[1]
        if entry:
            del _trend_cache[key]
    return None

def _trend_cache_set(key, value):
    with _trend_cache_lock:
        if len(_trend_cache) >= _TREND_CACHE_MAX:
            oldest_key = min(_trend_cache, key=lambda k: _trend_cache[k][0])
            del _trend_cache[oldest_key]
        _trend_cache[key] = (time.time(), value)


# =============================================
# Validation helpers
# =============================================

def safe_filename(filename):
    """Validates filename to prevent path traversal. Returns True if safe."""
    return bool(filename) and bool(re.match(r'^[a-zA-Z0-9._-]+$', filename))

def validate_name(name):
    """Validates device/tag/user names. Returns True if valid."""
    return bool(name) and bool(re.match(r'^[a-zA-Z0-9._-]{1,128}$', name))


def validate_tag_address(address, connection_string=""):
    """Validates a PLC4X tag address. Returns (ok, error_message).

    Checks protocol-specific rules to prevent the PLC4X server from
    crashing on startup due to invalid addresses.
    """
    if not address or not isinstance(address, str):
        return False, "Tag address cannot be empty"
    address = address.strip()

    # Modbus: holding-register, input-register, coil, discrete-input must have address >= 1
    modbus_pattern = re.match(
        r'^(holding-register|input-register|coil|discrete-input):(\d+)', address
    )
    if modbus_pattern:
        reg_type = modbus_pattern.group(1)
        reg_addr = int(modbus_pattern.group(2))
        if reg_addr < 1:
            return False, f"Modbus {reg_type} address must be >= 1 (got {reg_addr})"

    # OPC-UA: PLC4X only supports ns=N;i=ID or ns=N;s=STRING format
    conn_lower = connection_string.lower() if connection_string else ""
    if "opcua" in conn_lower or address.startswith("ns=") or address.startswith("nsu="):
        if address.startswith("nsu="):
            return False, "PLC4X does not support 'nsu=' (namespace URI) format. Use 'ns=N;i=ID' or 'ns=N;s=NAME' instead"
        if address.startswith("ns=") and not re.match(r'^ns=\d+;[isgb]=.+', address):
            return False, "Invalid OPC-UA address format. Use 'ns=N;i=ID' or 'ns=N;s=NAME' (e.g., ns=2;i=10 or ns=2;s=MyVar)"

    return True, None


def validate_device_tags(device):
    """Validates all tags in a device. Returns list of error strings (empty if ok)."""
    errors = []
    conn = device.get("connectionString", "")
    for tag in device.get("tags", []):
        alias = tag.get("alias", "unknown")
        address = tag.get("address", "")
        ok, msg = validate_tag_address(address, conn)
        if not ok:
            errors.append(f"Tag '{alias}': {msg}")
    return errors


# =============================================
# Authentication
# =============================================

def create_jwt_token(username, role="admin", plants=None):
    """Creates a JWT token for the given username."""
    payload = {
        "sub": username,
        "role": role,
        "iat": datetime.datetime.now(datetime.timezone.utc),
        "exp": datetime.datetime.now(datetime.timezone.utc) + datetime.timedelta(hours=JWT_EXPIRY_HOURS)
    }
    if plants:
        payload["plants"] = plants
    return jwt.encode(payload, JWT_SECRET, algorithm="HS256")


def get_user_plants():
    """Returns list of allowed plants for current user, or None if all allowed."""
    plants = getattr(g, "plants", None)
    return plants if plants else None


def filter_by_plant(items, plant_key="plant"):
    """Filters a list of dicts by the current user's allowed plants."""
    allowed = get_user_plants()
    if not allowed:
        return items
    return [item for item in items if item.get(plant_key) in allowed]


def verify_jwt_token(token):
    """Verifies a JWT token and returns the payload, or None if invalid."""
    try:
        return jwt.decode(token, JWT_SECRET, algorithms=["HS256"])
    except (jwt.ExpiredSignatureError, jwt.InvalidTokenError):
        return None


def verify_basic_auth(auth_header):
    """Verifies Basic Auth credentials. Returns (username, role, plants) or (None, None, None)."""
    try:
        scheme, credentials = auth_header.split(" ", 1)
        if scheme.lower() != "basic":
            return None, None, None
        decoded = base64.b64decode(credentials).decode("utf-8")
        username, password = decoded.split(":", 1)
        # Check against USERS dict first (supports all roles and plants)
        for uname, udata in USERS.items():
            if hmac.compare_digest(username, uname) and hmac.compare_digest(password, udata.get("password", "")):
                return uname, udata.get("role", "operator"), udata.get("plants")
        # Fall back to legacy ADMIN_USERNAME/ADMIN_PASSWORD check
        if hmac.compare_digest(username, ADMIN_USERNAME) and hmac.compare_digest(password, ADMIN_PASSWORD):
            return username, "admin", None
    except (ValueError, UnicodeDecodeError):
        pass
    return None, None, None


def verify_api_key(key):
    """Verifies an API key. Returns True if valid."""
    return bool(API_KEY) and hmac.compare_digest(key, API_KEY)


def require_admin(f):
    """Decorator that restricts an endpoint to admin role only."""
    from functools import wraps
    @wraps(f)
    def decorated(*args, **kwargs):
        if getattr(g, "role", "monitor") != "admin":
            return jsonify({"error": "Admin access required"}), 403
        return f(*args, **kwargs)
    return decorated


def require_operator(f):
    """Decorator that restricts an endpoint to admin or operator (not monitor)."""
    from functools import wraps
    @wraps(f)
    def decorated(*args, **kwargs):
        if getattr(g, "role", "monitor") not in ("admin", "operator"):
            return jsonify({"error": "Operator access required"}), 403
        return f(*args, **kwargs)
    return decorated


@app.before_request
def authenticate():
    """Authenticates all requests to /api/* endpoints.

    Supports three authentication methods:
    1. JWT Bearer token (Authorization: Bearer <token>)
    2. HTTP Basic Auth (Authorization: Basic <base64>)
    3. API Key (X-API-Key: <key>)

    Public endpoints (no auth required):
    - GET / (web UI)
    - GET /login (login page)
    - POST /api/auth/login (get JWT token)
    - GET /static/* (CSS, JS assets)
    """
    # Public routes - no auth required
    if request.path in ("/", "/login") or request.path.startswith("/static/"):
        return None
    if request.path == "/api/auth/login" and request.method == "POST":
        return None

    # Allow token via query parameter for file downloads
    query_token = request.args.get("token", "")
    if query_token and "/download" in request.path:
        payload = verify_jwt_token(query_token)
        if payload:
            g.user = payload.get("sub")
            g.role = payload.get("role", "monitor")
            g.plants = payload.get("plants")
            return None

    # Check Authorization header
    auth_header = request.headers.get("Authorization", "")

    # Method 1: JWT Bearer token
    if auth_header.lower().startswith("bearer "):
        token = auth_header.split(" ", 1)[1]
        payload = verify_jwt_token(token)
        if payload:
            g.user = payload.get("sub")
            g.role = payload.get("role", "monitor")
            g.plants = payload.get("plants")
            return None
        return jsonify({"error": "Invalid or expired token"}), 401

    # Method 2: Basic Auth
    if auth_header.lower().startswith("basic "):
        username, role, plants = verify_basic_auth(auth_header)
        if username:
            g.user = username
            g.role = role
            g.plants = plants
            return None
        return jsonify({"error": "Invalid credentials"}), 401

    # Method 3: API Key
    api_key = request.headers.get("X-API-Key", "")
    if api_key:
        if verify_api_key(api_key):
            g.user = "api-key"
            g.role = "admin"
            g.plants = None
            return None
        return jsonify({"error": "Invalid API key"}), 401

    # No authentication provided
    return jsonify({"error": "Authentication required"}), 401


# =============================================
# Audit Trail
# =============================================

def audit_log(action, details=None, user=None):
    """Append a structured audit event to the audit trail file."""
    entry = {
        "timestamp": datetime.datetime.now(datetime.timezone.utc).isoformat(),
        "user": user or (getattr(g, "user", "system") if has_request_context() else "system"),
        "action": action,
        "ip": request.remote_addr if has_request_context() else None,
    }
    if details:
        entry["details"] = details
    try:
        with AUDIT_LOCK:
            with open(AUDIT_TRAIL_PATH, "a", encoding="utf-8") as f:
                f.write(_json.dumps(entry) + "\n")
    except Exception:
        pass


# Endpoints that should NOT be audited (read-only, high-frequency, or auth-checked separately)
_AUDIT_SKIP = {"/api/live/read", "/api/alarms", "/api/server/status", "/api/server/logs",
               "/api/devices", "/api/backups", "/api/templates", "/api/security/status",
               "/api/security/certificates/trusted", "/api/security/certificates/rejected",
               "/api/users", "/api/hmi/config", "/api/services/status", "/api/plc4x/version",
               "/api/plc4x/latest-version", "/api/manager/version", "/api/manager/check-update",
               "/api/auth/verify", "/api/export/csv",
               "/api/export/pdf", "/api/oee/calculate", "/api/oee/trend", "/api/audit",
               "/api/live/write-log", "/api/data/query"}


@app.after_request
def audit_after_request(response):
    """Automatically audit all successful write operations (POST/PUT/DELETE)."""
    if request.method in ("POST", "PUT", "DELETE") and request.path.startswith("/api/"):
        # Skip high-frequency or read-only endpoints
        path = request.path.rstrip("/")
        if path in _AUDIT_SKIP:
            return response
        # Skip failed requests
        if response.status_code >= 400:
            return response
        # Build action name from method + path
        action = f"{request.method} {path}"
        details = None
        try:
            resp_data = response.get_json(silent=True)
            if resp_data and isinstance(resp_data, dict):
                msg = resp_data.get("message")
                if msg:
                    details = {"message": msg}
                else:
                    # Capture key identifiers from response (name, id, alias, etc.)
                    summary = {}
                    for key in ("name", "id", "alias", "key", "oeeConfig"):
                        if key in resp_data:
                            val = resp_data[key]
                            summary[key] = val if isinstance(val, (str, int, float, bool)) else str(val)[:80]
                    if summary:
                        details = summary
        except Exception:
            pass
        # Also capture key info from request body
        if not details:
            try:
                req_data = request.get_json(silent=True)
                if req_data and isinstance(req_data, dict):
                    summary = {}
                    for key in ("name", "device", "tag", "alias", "key", "enabled"):
                        if key in req_data:
                            summary[key] = req_data[key]
                    if summary:
                        details = summary
            except Exception:
                pass
        audit_log(action, details)
        # Periodically trim (1% chance per write request)
        if _random.random() < 0.01:
            _trim_audit_trail()
    return response


def _trim_jsonl_file(filepath, lock, max_lines, max_days):
    """Trim a JSONL file by max lines and max age (days)."""
    import json as _j
    try:
        cutoff = (datetime.datetime.utcnow() - datetime.timedelta(days=max_days)).isoformat()
        with lock:
            with open(filepath, "r", encoding="utf-8") as f:
                lines = f.readlines()
            if len(lines) <= max_lines:
                # Only check time-based retention if under line cap
                kept = []
                for line in lines:
                    try:
                        entry = _j.loads(line)
                        if entry.get("timestamp", "") >= cutoff:
                            kept.append(line)
                    except Exception:
                        kept.append(line)
                if len(kept) < len(lines):
                    with open(filepath, "w", encoding="utf-8") as f:
                        f.writelines(kept)
            else:
                # Over line cap — trim to max_lines, then apply time filter
                recent = lines[-max_lines:]
                kept = []
                for line in recent:
                    try:
                        entry = _j.loads(line)
                        if entry.get("timestamp", "") >= cutoff:
                            kept.append(line)
                    except Exception:
                        kept.append(line)
                with open(filepath, "w", encoding="utf-8") as f:
                    f.writelines(kept)
    except Exception:
        pass


def _trim_audit_trail():
    _trim_jsonl_file(AUDIT_TRAIL_PATH, AUDIT_LOCK, AUDIT_TRAIL_MAX_LINES, AUDIT_TRAIL_MAX_DAYS)


