# =============================================
# Helpers - Config
# =============================================

def _atomic_yaml_write(filepath, data):
    """Writes YAML data to a file atomically using tempfile + os.replace."""
    dir_name = os.path.dirname(filepath)
    os.makedirs(dir_name, exist_ok=True)
    fd, tmp_path = tempfile.mkstemp(dir=dir_name, suffix=".yml.tmp")
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as f:
            yaml.dump(data, f, default_flow_style=False, allow_unicode=True, sort_keys=False)
        os.replace(tmp_path, filepath)
    except Exception:
        try:
            os.unlink(tmp_path)
        except OSError:
            pass
        raise


HMI_CONFIG_PATH = os.path.join(os.path.dirname(os.environ.get("CONFIG_PATH", "/app/config/config.yml")), "hmi-screens.json")
HMI_IMAGES_DIR = os.path.join(os.path.dirname(os.path.abspath(__file__)), "static", "hmi-images")
HMI_ALLOWED_EXTENSIONS = {".png", ".jpg", ".jpeg", ".svg", ".gif", ".webp"}


def load_hmi_config():
    """Loads HMI config from hmi-screens.json. Returns default if not found."""
    try:
        with open(HMI_CONFIG_PATH, "r", encoding="utf-8") as f:
            return _json.load(f)
    except (FileNotFoundError, _json.JSONDecodeError):
        return {"plants": []}


def save_hmi_config(config):
    """Saves HMI config to hmi-screens.json atomically."""
    tmp = HMI_CONFIG_PATH + ".tmp"
    os.makedirs(os.path.dirname(HMI_CONFIG_PATH), exist_ok=True)
    with open(tmp, "w", encoding="utf-8") as f:
        _json.dump(config, f, indent=2)
    os.replace(tmp, HMI_CONFIG_PATH)


def _find_plant(config, pid):
    """Finds a plant by id. Returns (index, plant) or (None, None)."""
    for i, plant in enumerate(config.get("plants", [])):
        if plant.get("id") == pid:
            return i, plant
    return None, None


def _find_area(config, aid):
    """Finds an area by id across all plants. Returns (plant_index, area_index, area) or (None, None, None)."""
    for pi, plant in enumerate(config.get("plants", [])):
        for ai, area in enumerate(plant.get("areas", [])):
            if area.get("id") == aid:
                return pi, ai, area
    return None, None, None


def _find_equipment(config, eid):
    """Finds equipment by id across all areas. Returns (pi, ai, ei, equip) or (None, None, None, None)."""
    for pi, plant in enumerate(config.get("plants", [])):
        for ai, area in enumerate(plant.get("areas", [])):
            for ei, equip in enumerate(area.get("equipment", [])):
                if equip.get("id") == eid:
                    return pi, ai, ei, equip
    return None, None, None, None


def _safe_image_filename(filename):
    """Returns a safe version of the filename for HMI image uploads."""
    name, ext = os.path.splitext(filename)
    # Sanitize: keep only alphanumeric, dash, underscore, dot
    name = re.sub(r'[^a-zA-Z0-9._-]', '_', name)
    name = name[:80]  # Limit length
    return name + ext.lower()


def _find_device(config, name):
    """Finds a device by name in the config. Returns (index, device) or (None, None)."""
    for i, device in enumerate(config.get("devices", [])):
        if device["name"] == name:
            return i, device
    return None, None


def load_config():
    """Loads config from admin file (has calculatedTags), falls back to server config."""
    for path in [CONFIG_PATH + ".admin", CONFIG_PATH]:
        try:
            with open(path, "r", encoding="utf-8") as f:
                return yaml.safe_load(f)
        except FileNotFoundError:
            continue
    return get_default_config()


ADMIN_CONFIG_PATH = CONFIG_PATH + ".admin"


def save_config(config):
    """Saves configuration files.

    Writes two files:
    - config.yml: Clean config for PLC4X server (no calculatedTags)
    - config.yml.admin: Full config with calculatedTags for admin panel

    Callers must hold CONFIG_LOCK for read-modify-write operations.
    """
    import copy
    os.makedirs(BACKUP_DIR, exist_ok=True)

    # Backup the full admin config
    if os.path.exists(ADMIN_CONFIG_PATH):
        ts = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
        backup_path = os.path.join(BACKUP_DIR, f"config_{ts}.yml")
        with open(ADMIN_CONFIG_PATH, "r", encoding="utf-8") as src:
            with open(backup_path, "w", encoding="utf-8") as dst:
                dst.write(src.read())

    # Save full config (with calculatedTags) for admin panel
    _atomic_yaml_write(ADMIN_CONFIG_PATH, config)

    # Save clean config for PLC4X server:
    # - Strip calculatedTags (PLC4X doesn't know about them)
    # - Strip disabled devices (enabled: false)
    server_config = copy.deepcopy(config)
    server_config["devices"] = [
        d for d in server_config.get("devices", [])
        if d.get("enabled", True) is not False
    ]
    for device in server_config["devices"]:
        device.pop("calculatedTags", None)
        device.pop("enabled", None)
        device.pop("allowWrite", None)
        device.pop("pollInterval", None)
        device.pop("plant", None)
        device.pop("oeeConfig", None)
        # Strip admin-only fields from tags and remove virtual tags
        device["tags"] = [t for t in device.get("tags", [])
                         if not t.get("address", "").upper().startswith("VIRTUAL")]
        for tag in device.get("tags", []):
            tag.pop("alarmThresholds", None)
    _atomic_yaml_write(CONFIG_PATH, server_config)

    cleanup_old_backups()


def cleanup_old_backups():
    """Removes old backups keeping only the most recent BACKUP_MAX_FILES."""
    if not os.path.exists(BACKUP_DIR):
        return
    files = sorted(
        [f for f in os.listdir(BACKUP_DIR) if f.endswith(".yml")],
        reverse=True
    )
    for old_file in files[BACKUP_MAX_FILES:]:
        try:
            os.remove(os.path.join(BACKUP_DIR, old_file))
        except OSError:
            pass


def get_default_config():
    """Returns a default configuration with no devices. Use Load Demo Devices to add examples."""
    return {
        "version": "0.8",
        "dir": "/app/security",
        "name": "Plc4xOPCUAServer",
        "disableInsecureEndpoint": False,
        "tcpPort": 12687,
        "devices": []
    }


# =============================================
# Helpers - Docker
# =============================================

_docker_client = None
def get_docker_client():
    """Returns a singleton Docker client."""
    global _docker_client
    if _docker_client is None:
        _docker_client = docker.DockerClient(base_url="unix:///var/run/docker.sock")
    return _docker_client


def get_server_status():
    """Checks the PLC4X Server container status."""
    try:
        client = get_docker_client()
        container = client.containers.get(PLC4X_CONTAINER)
        return {
            "status": container.status,
            "running": container.status == "running",
            "id": container.short_id,
            "image": container.image.tags[0] if container.image.tags else "unknown"
        }
    except docker.errors.NotFound:
        return {"status": "not_found", "running": False, "id": None, "image": None}
    except Exception as e:
        return {"status": "error", "running": False, "id": None, "image": None, "error": str(e)}


# =============================================
# Helpers - Password / Users (.jibberish)
# =============================================

def load_password_config():
    """Loads the password configuration from .jibberish file."""
    try:
        with open(PASSWORD_FILE, "r", encoding="utf-8") as f:
            return yaml.safe_load(f)
    except FileNotFoundError:
        return None


def save_password_config(pwd_config):
    """Saves the password configuration to .jibberish file."""
    _atomic_yaml_write(PASSWORD_FILE, pwd_config)


def hash_password(plaintext, salt_bytes=None):
    """Hashes a password using the PLC4X format: SHA-256(base64(salt) + ':' + password)."""
    if salt_bytes is None:
        salt_bytes = secrets.token_bytes(16)
    salt_b64 = base64.b64encode(salt_bytes).decode("utf-8")
    to_hash = f"{salt_b64}:{plaintext}"
    hash_hex = hashlib.sha256(to_hash.encode("utf-8")).hexdigest()
    return hash_hex, salt_b64, salt_bytes


def jetty_obfuscate(password):
    """Obfuscates a password using Jetty's OBF encoding (without the 'OBF:' prefix)."""
    buf = []
    for i, c in enumerate(password):
        b1 = 127 + ord(c) + i
        b2 = 127 + ord(c) - i
        i1 = 0xff & (b1 >> 8)
        i2 = 0xff & b1
        i3 = 0xff & (b2 >> 8)
        i4 = 0xff & b2
        buf.append(f"{i1:04x}{i2:04x}{i3:04x}{i4:04x}")
    return "".join(buf)


def jetty_deobfuscate(obfuscated):
    """Deobfuscates a Jetty OBF-encoded password (without the 'OBF:' prefix)."""
    result = []
    for i in range(0, len(obfuscated), 16):
        chunk = obfuscated[i:i+16]
        if len(chunk) < 16:
            break
        i0 = int(chunk[0:4], 16)
        i1 = int(chunk[4:8], 16)
        i2 = int(chunk[8:12], 16)
        i3 = int(chunk[12:16], 16)
        val1 = (i0 << 8) + i1
        val2 = (i2 << 8) + i3
        c = (val1 + val2 - 254) >> 1
        result.append(chr(c))
    return "".join(result)


# =============================================
# Helpers - PKI Certificates
# =============================================

def list_pki_certificates(subdir):
    """Lists certificate files in a PKI subdirectory (trusted/rejected)."""
    cert_dir = os.path.join(PKI_DIR, subdir)
    if not os.path.exists(cert_dir):
        return []
    certs = []
    for f in sorted(os.listdir(cert_dir)):
        if f.endswith((".der", ".pem", ".crt", ".cer")):
            filepath = os.path.join(cert_dir, f)
            stat = os.stat(filepath)
            certs.append({
                "filename": f,
                "size": stat.st_size,
                "modified": stat.st_mtime
            })
    return certs


# =============================================
# Routes - REST API: Configuration
