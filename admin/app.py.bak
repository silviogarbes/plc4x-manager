@app.route("/api/devices/<device_name>/tags", methods=["GET"])
def api_list_tags(device_name):
    """Lists tags for a device."""
    allowed = getattr(g, "plants", None)
    if allowed:
        config = load_config()
        device = config.get("devices", {}).get(device_name, {})
        if device.get("plant") not in allowed:
            return jsonify({"error": "Access denied"}), 403
    config = load_config()
    _, device = _find_device(config, device_name)
    if device is None:
        return jsonify({"error": f"Device '{device_name}' not found"}), 404
    return jsonify(device.get("tags", []))


@app.route("/api/devices/<device_name>/tags", methods=["POST"])
@require_admin
def api_add_tag(device_name):
    """Adds a tag to a device."""
    tag = request.get_json()
    if not tag or "alias" not in tag or "address" not in tag:
        return jsonify({"error": "Fields 'alias' and 'address' are required"}), 400

    if not validate_name(tag["alias"]):
        return jsonify({"error": "Invalid tag alias. Use only letters, numbers, dots, hyphens, underscores (max 128 chars)"}), 400

    with CONFIG_LOCK:
        config = load_config()
        _, device = _find_device(config, device_name)
        if device is None:
            return jsonify({"error": f"Device '{device_name}' not found"}), 404

        # Validate tag address
        ok, msg = validate_tag_address(tag.get("address", ""), device.get("connectionString", ""))
        if not ok:
            return jsonify({"error": msg}), 400

        tags = device.get("tags", [])
        if any(t["alias"] == tag["alias"] for t in tags):
            return jsonify({"error": f"Tag '{tag['alias']}' already exists"}), 409
        tags.append(tag)
        device["tags"] = tags
        save_config(config)
    return jsonify({"message": f"Tag '{tag['alias']}' added"}), 201


@app.route("/api/devices/<device_name>/tags/<alias>", methods=["DELETE"])
@require_admin
def api_delete_tag(device_name, alias):
    """Removes a tag from a device."""
    with CONFIG_LOCK:
        config = load_config()
        _, device = _find_device(config, device_name)
        if device is None:
            return jsonify({"error": f"Device '{device_name}' not found"}), 404
        tags = device.get("tags", [])
        original_len = len(tags)
        tags = [t for t in tags if t["alias"] != alias]
        if len(tags) == original_len:
            return jsonify({"error": f"Tag '{alias}' not found"}), 404
        device["tags"] = tags
        save_config(config)
    return jsonify({"message": f"Tag '{alias}' removed"})


def _validate_threshold_values(data):
    """Extract and validate threshold values from a dict. Returns (thresholds, error_tuple_or_None)."""
    import math
    thresholds = {}
    for key in ("warningHigh", "warningLow", "criticalHigh", "criticalLow"):
        val = data.get(key)
        if val is not None:
            try:
                thresholds[key] = float(val)
                if not math.isfinite(thresholds[key]):
                    return None, (jsonify({"error": f"Invalid value for '{key}': must be a finite number"}), 400)
            except (ValueError, TypeError):
                return None, (jsonify({"error": f"Invalid value for '{key}'"}), 400)
    cl = thresholds.get("criticalLow")
    wl = thresholds.get("warningLow")
    wh = thresholds.get("warningHigh")
    ch = thresholds.get("criticalHigh")
    if cl is not None and wl is not None and cl > wl:
        return None, (jsonify({"error": "Critical Low must be <= Warning Low"}), 400)
    if wh is not None and ch is not None and wh > ch:
        return None, (jsonify({"error": "Warning High must be <= Critical High"}), 400)
    if wl is not None and wh is not None and wl > wh:
        return None, (jsonify({"error": "Warning Low must be <= Warning High"}), 400)
    return thresholds, None


@app.route("/api/devices/<device_name>/tags/<alias>/alarms", methods=["PUT"])
@require_admin
def api_set_tag_alarms(device_name, alias):
    """Sets alarm thresholds for a tag.

    Simple (fixed thresholds):
      {warningHigh, warningLow, criticalHigh, criticalLow}

    Conditional (thresholds depend on another tag's value):
      {
        conditionDevice: "DeviceName",
        conditionTag: "ProductCode",
        profiles: [
          {whenValue: 1, label: "Product A", warningLow: 20, warningHigh: 30, ...},
          {whenValue: 2, label: "Product B", warningLow: 15, warningHigh: 25, ...}
        ],
        warningHigh, warningLow, criticalHigh, criticalLow  // default when no profile matches
      }

    Pass empty object {} to clear all.
    """
    data = request.get_json()
    if data is None:
        return jsonify({"error": "Request body is required"}), 400

    with CONFIG_LOCK:
        config = load_config()
        _, device = _find_device(config, device_name)
        if device is None:
            return jsonify({"error": f"Device '{device_name}' not found"}), 404
        tag = next((t for t in device.get("tags", []) if t["alias"] == alias), None)
        if not tag:
            return jsonify({"error": f"Tag '{alias}' not found"}), 404

        # Validate default thresholds
        thresholds, err = _validate_threshold_values(data)
        if err:
            return err

        # Handle conditional profiles
        condition_device = data.get("conditionDevice")
        condition_tag = data.get("conditionTag")
        profiles = data.get("profiles")

        if profiles is not None:
            if not isinstance(profiles, list):
                return jsonify({"error": "'profiles' must be an array"}), 400
            validated_profiles = []
            for i, p in enumerate(profiles):
                if "whenValue" not in p:
                    return jsonify({"error": f"Profile {i+1}: 'whenValue' is required"}), 400
                if not isinstance(p["whenValue"], (str, int, float)):
                    return jsonify({"error": f"Profile {i+1}: 'whenValue' must be a string or number"}), 400
                p_thresholds, p_err = _validate_threshold_values(p)
                if p_err:
                    return p_err
                entry = {"whenValue": p["whenValue"]}
                if p.get("label"):
                    entry["label"] = str(p["label"])
                entry.update(p_thresholds)
                validated_profiles.append(entry)
            if validated_profiles and not condition_tag:
                return jsonify({"error": "Condition Tag is required when profiles are defined"}), 400
            thresholds["profiles"] = validated_profiles
            if condition_device:
                thresholds["conditionDevice"] = str(condition_device)
            if condition_tag:
                thresholds["conditionTag"] = str(condition_tag)

        if thresholds:
            tag["alarmThresholds"] = thresholds
        else:
            tag.pop("alarmThresholds", None)

        save_config(config)

    return jsonify({"message": f"Alarm thresholds updated for '{alias}'", "alarmThresholds": thresholds})


