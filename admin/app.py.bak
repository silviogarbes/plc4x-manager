@app.route("/api/devices", methods=["GET"])
def api_list_devices():
    """Lists all devices (filtered by user's allowed plants)."""
    devices = load_config().get("devices", [])
    return jsonify(filter_by_plant(devices))


@app.route("/api/devices", methods=["POST"])
@require_admin
def api_add_device():
    """Adds a new device."""
    device = request.get_json()
    if not device or "name" not in device or "connectionString" not in device:
        return jsonify({"error": "Fields 'name' and 'connectionString' are required"}), 400

    if not validate_name(device["name"]):
        return jsonify({"error": "Invalid device name. Use only letters, numbers, dots, hyphens, underscores (max 128 chars)"}), 400

    with CONFIG_LOCK:
        config = load_config()
        devices = config.get("devices", [])
        if any(d["name"] == device["name"] for d in devices):
            return jsonify({"error": f"Device '{device['name']}' already exists"}), 409

        if "tags" not in device:
            device["tags"] = []

        # Validate all tag addresses
        tag_errors = validate_device_tags(device)
        if tag_errors:
            return jsonify({"error": "Invalid tags: " + "; ".join(tag_errors)}), 400

        devices.append(device)
        config["devices"] = devices
        save_config(config)
    return jsonify({"message": f"Device '{device['name']}' added"}), 201


@app.route("/api/devices/<name>", methods=["PUT"])
@require_admin
def api_update_device(name):
    """Updates an existing device."""
    data = request.get_json()
    if not data or "name" not in data or "connectionString" not in data:
        return jsonify({"error": "Fields 'name' and 'connectionString' are required"}), 400
    if not validate_name(data["name"]):
        return jsonify({"error": "Invalid device name"}), 400
    with CONFIG_LOCK:
        config = load_config()
        i, _ = _find_device(config, name)
        if i is None:
            return jsonify({"error": f"Device '{name}' not found"}), 404

        # Validate all tag addresses
        tag_errors = validate_device_tags(data)
        if tag_errors:
            return jsonify({"error": "Invalid tags: " + "; ".join(tag_errors)}), 400

        config["devices"][i] = data
        save_config(config)
    return jsonify({"message": f"Device '{name}' updated"})


@app.route("/api/devices/<name>", methods=["DELETE"])
@require_admin
def api_delete_device(name):
    """Removes a device."""
    with CONFIG_LOCK:
        config = load_config()
        i, _ = _find_device(config, name)
        if i is None:
            return jsonify({"error": f"Device '{name}' not found"}), 404
        config["devices"].pop(i)
        save_config(config)
    return jsonify({"message": f"Device '{name}' removed"})


