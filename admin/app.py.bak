@app.route("/login")
def login_page():
    """Serves the login page."""
    return render_template("login.html")


# Brute force protection: file-based tracking shared across workers
LOGIN_MAX_ATTEMPTS = 5
LOGIN_LOCKOUT_SECONDS = 300  # 5 minutes
_LOGIN_FILE = "/tmp/plc4x_login_failures.yml"
_LOGIN_LOCK = FileLock("/tmp/plc4x_login.lock", timeout=5)


def _load_login_failures():
    try:
        with open(_LOGIN_FILE, "r") as f:
            return yaml.safe_load(f) or {}
    except FileNotFoundError:
        return {}


def _save_login_failures(data):
    with open(_LOGIN_FILE, "w") as f:
        yaml.dump(data, f)


@app.route("/api/auth/login", methods=["POST"])
@limiter.limit("30 per minute")
def api_login():
    """Authenticates and returns a JWT token.

    Brute force protection: after 5 failed attempts, the IP is locked out
    for 5 minutes. Rate limiting also applies (10 requests/minute).
    """
    client_ip = request.remote_addr or "unknown"
    now = datetime.datetime.now(datetime.timezone.utc).timestamp()

    with _LOGIN_LOCK:
        failures = _load_login_failures()

    # Check if IP is locked out
    fail_info = failures.get(client_ip, {})
    if fail_info.get("locked_until", 0) > now:
        remaining = int(fail_info["locked_until"] - now)
        return jsonify({
            "error": f"Too many failed attempts. Try again in {remaining} seconds.",
            "locked": True,
            "retryAfter": remaining
        }), 429

    data = request.get_json()
    if not data or "username" not in data or "password" not in data:
        return jsonify({"error": "Fields 'username' and 'password' are required"}), 400

    username = data["username"]
    password = data["password"]

    user_entry = USERS.get(username)
    # Constant-time compare even when user not found (prevent timing oracle)
    stored_pass = user_entry["password"] if user_entry else "dummy"
    if user_entry and hmac.compare_digest(password, stored_pass):
        # Successful login - clear failures
        with _LOGIN_LOCK:
            failures = _load_login_failures()
            failures.pop(client_ip, None)
            _save_login_failures(failures)
        role = user_entry.get("role", "operator")
        plants = user_entry.get("plants")  # list of allowed plants, or None for all
        token = create_jwt_token(username, role, plants)
        audit_log("login", {"status": "success", "role": role, "plants": plants}, user=username)
        resp = {"token": token, "username": username, "role": role, "expiresIn": JWT_EXPIRY_HOURS * 3600}
        if plants:
            resp["plants"] = plants
        return jsonify(resp)

    # Failed login - track attempts (shared across workers via file)
    with _LOGIN_LOCK:
        failures = _load_login_failures()
        if client_ip not in failures:
            failures[client_ip] = {"count": 0, "locked_until": 0}
        failures[client_ip]["count"] += 1
        attempts = failures[client_ip]["count"]

        if attempts >= LOGIN_MAX_ATTEMPTS:
            failures[client_ip]["locked_until"] = now + LOGIN_LOCKOUT_SECONDS

        _save_login_failures(failures)

    if attempts >= LOGIN_MAX_ATTEMPTS:
        return jsonify({
            "error": f"Account locked for {LOGIN_LOCKOUT_SECONDS // 60} minutes after {LOGIN_MAX_ATTEMPTS} failed attempts.",
            "locked": True,
            "retryAfter": LOGIN_LOCKOUT_SECONDS
        }), 429

    remaining_attempts = LOGIN_MAX_ATTEMPTS - attempts
    audit_log("login_failed", {"username": username, "attempts": attempts}, user=username)
    return jsonify({
        "error": f"Invalid credentials. {remaining_attempts} attempt(s) remaining before lockout."
    }), 401


@app.route("/api/auth/verify", methods=["GET"])
def api_verify():
    """Verifies the current authentication is valid.

    Returns the authenticated username.
    """
    return jsonify({"username": g.get("user", "unknown"), "authenticated": True})


@app.route("/api/auth/refresh", methods=["POST"])
def api_refresh():
    """Refreshes the current JWT token (issues a new one)."""
    username = g.get("user")
    if not username:
        return jsonify({"error": "Not authenticated"}), 401
    role = getattr(g, "role", "monitor")
    plants = getattr(g, "plants", None)
    token = create_jwt_token(username, role, plants)
    return jsonify({
        "token": token,
        "username": username,
        "role": role,
        "expiresIn": JWT_EXPIRY_HOURS * 3600
    })


@app.route("/api/auth/password", methods=["PUT"])
@require_admin
def api_change_admin_password():
    """Changes the admin panel password.

    Writes the new credentials to a persistent file so they survive restarts.
    The .env file is not writable from inside the container, so we store
    the override in a config file that gets loaded at startup.
    """
    data = request.get_json()
    if not data or "password" not in data:
        return jsonify({"error": "Field 'password' is required"}), 400
    new_password = data["password"]
    if not new_password or len(new_password) < 4:
        return jsonify({"error": "Password must be at least 4 characters"}), 400

    # Store credentials override in a persistent file
    creds_path = os.path.join(os.path.dirname(CONFIG_PATH), ".admin-credentials")
    creds = {"username": ADMIN_USERNAME, "password": new_password}
    _atomic_yaml_write(creds_path, creds)

    # Update in-memory password for immediate effect
    global ADMIN_PASSWORD
    ADMIN_PASSWORD = new_password
    if ADMIN_USERNAME in USERS:
        USERS[ADMIN_USERNAME]["password"] = new_password

    return jsonify({"message": "Admin password changed. You will need to log in again."})


@app.route("/api/auth/info", methods=["GET"])
def api_auth_info():
    """Returns the current admin username (for UI display)."""
    return jsonify({"username": ADMIN_USERNAME})


