@app.route("/api/hmi/equipment/<eid>", methods=["PUT"])
@require_admin
def api_hmi_update_equipment(eid):
    """Updates equipment name and/or device."""
    data = request.get_json()
    if not data:
        return jsonify({"error": "Request body is required"}), 400
    config = load_hmi_config()
    pi, ai, ei, equip = _find_equipment(config, eid)
    if equip is None:
        return jsonify({"error": f"Equipment '{eid}' not found"}), 404
    if "name" in data and data["name"].strip():
        config["plants"][pi]["areas"][ai]["equipment"][ei]["name"] = data["name"].strip()
    if "device" in data:
        config["plants"][pi]["areas"][ai]["equipment"][ei]["device"] = data["device"]
    save_hmi_config(config)
    return jsonify(config["plants"][pi]["areas"][ai]["equipment"][ei])


@app.route("/api/hmi/equipment/<eid>", methods=["DELETE"])
@require_admin
def api_hmi_delete_equipment(eid):
    """Deletes equipment."""
    config = load_hmi_config()
    pi, ai, ei, equip = _find_equipment(config, eid)
    if equip is None:
        return jsonify({"error": f"Equipment '{eid}' not found"}), 404
    config["plants"][pi]["areas"][ai]["equipment"].pop(ei)
    save_hmi_config(config)
    return jsonify({"message": f"Equipment '{eid}' deleted"})


@app.route("/api/hmi/equipment/<eid>/screen", methods=["PUT"])
@require_admin
def api_hmi_save_screen(eid):
    """Saves the screen configuration (elements array) for an equipment."""
    data = request.get_json()
    if not isinstance(data, dict):
        return jsonify({"error": "Invalid screen config: expected a JSON object"}), 400
    config = load_hmi_config()
    pi, ai, ei, equip = _find_equipment(config, eid)
    if equip is None:
        return jsonify({"error": f"Equipment '{eid}' not found"}), 404
    screen = config["plants"][pi]["areas"][ai]["equipment"][ei].setdefault("screen", {})
    if "elements" in data:
        screen["elements"] = data["elements"]
    if "backgroundImage" in data:
        screen["backgroundImage"] = data["backgroundImage"]
    if "width" in data:
        screen["width"] = data["width"]
    if "height" in data:
        screen["height"] = data["height"]
    save_hmi_config(config)
    return jsonify(config["plants"][pi]["areas"][ai]["equipment"][ei])


@app.route("/api/hmi/upload-image", methods=["POST"])
@require_admin
def api_hmi_upload_image():
    """Uploads a background image for HMI screens.

    Accepts multipart/form-data with a 'file' field.
    Saves to admin/static/hmi-images/ with a safe filename.
    Returns: {"url": "/static/hmi-images/filename.ext"}
    """
    if "file" not in request.files:
        return jsonify({"error": "No file uploaded"}), 400
    file = request.files["file"]
    if not file.filename:
        return jsonify({"error": "No filename provided"}), 400
    ext = os.path.splitext(file.filename)[1].lower()
    if ext not in HMI_ALLOWED_EXTENSIONS:
        allowed = ", ".join(sorted(HMI_ALLOWED_EXTENSIONS))
        return jsonify({"error": f"File type not allowed. Allowed: {allowed}"}), 400
    safe_name = _safe_image_filename(file.filename)
    os.makedirs(HMI_IMAGES_DIR, exist_ok=True)
    save_path = os.path.join(HMI_IMAGES_DIR, safe_name)
    file.save(save_path)
    return jsonify({"url": f"/static/hmi-images/{safe_name}"})


@app.route("/api/hmi/load-demo", methods=["POST"])
@require_admin
def api_hmi_load_demo():
    """Loads demo HMI config from hmi-demo.json and merges into existing config.

    Does not overwrite existing plants — only adds plants from the demo
    that do not already exist (matched by name).
    """
    demo_path = os.path.join(os.path.dirname(os.path.abspath(__file__)), "hmi-demo.json")
    try:
        with open(demo_path, "r", encoding="utf-8") as f:
            demo = _json.load(f)
    except FileNotFoundError:
        return jsonify({"error": "hmi-demo.json not found"}), 404
    except _json.JSONDecodeError as e:
        return jsonify({"error": f"hmi-demo.json is invalid JSON: {e}"}), 500

    config = load_hmi_config()
    existing_names = {p["name"] for p in config.get("plants", [])}
    added = 0
    for plant in demo.get("plants", []):
        if plant.get("name") not in existing_names:
            config.setdefault("plants", []).append(plant)
            existing_names.add(plant["name"])
            added += 1
    save_hmi_config(config)
    return jsonify({"message": f"Demo loaded: {added} plant(s) added", "plantsAdded": added})


# =============================================
# Routes - REST API: Calculated Tags
# =============================================

@app.route("/api/devices/<device_name>/calculated", methods=["GET"])
def api_list_calculated_tags(device_name):
    """Lists calculated tags for a device."""
    allowed = getattr(g, "plants", None)
    if allowed:
        config = load_config()
        device = config.get("devices", {}).get(device_name, {})
        if device.get("plant") not in allowed:
            return jsonify({"error": "Access denied"}), 403
    config = load_config()
    _, device = _find_device(config, device_name)
    if device is None:
        return jsonify({"error": f"Device '{device_name}' not found"}), 404
    return jsonify(device.get("calculatedTags", []))


@app.route("/api/devices/<device_name>/calculated", methods=["POST"])
@require_admin
def api_add_calculated_tag(device_name):
    """Adds a calculated tag to a device."""
    data = request.get_json()
    if not data or "alias" not in data or "formula" not in data:
        return jsonify({"error": "Fields 'alias' and 'formula' are required"}), 400
    if not validate_name(data["alias"]):
        return jsonify({"error": "Invalid alias. Use only letters, numbers, dots, hyphens, underscores (max 128 chars)"}), 400

    # Validate formula syntax
    try:
        ast.parse(data["formula"], mode="eval")
    except SyntaxError:
        return jsonify({"error": "Invalid formula syntax"}), 400

    with CONFIG_LOCK:
        config = load_config()
        idx, device = _find_device(config, device_name)
        if device is None:
            return jsonify({"error": f"Device '{device_name}' not found"}), 404

        calc_tags = device.get("calculatedTags", [])
        # Check alias doesn't conflict with regular tags or other calculated tags
        all_aliases = [t["alias"] for t in device.get("tags", [])] + [t["alias"] for t in calc_tags]
        if data["alias"] in all_aliases:
            return jsonify({"error": f"Alias '{data['alias']}' already exists (in tags or calculated tags)"}), 409

        calc_tags.append({"alias": data["alias"], "formula": data["formula"]})
        device["calculatedTags"] = calc_tags
        config["devices"][idx] = device
        save_config(config)

    return jsonify({"message": f"Calculated tag '{data['alias']}' added"}), 201


@app.route("/api/devices/<device_name>/calculated/<alias>", methods=["PUT"])
@require_admin
def api_update_calculated_tag(device_name, alias):
    """Updates a calculated tag's formula."""
    data = request.get_json()
    if not data or "formula" not in data:
        return jsonify({"error": "Field 'formula' is required"}), 400

    try:
        ast.parse(data["formula"], mode="eval")
    except SyntaxError:
        return jsonify({"error": "Invalid formula syntax"}), 400

    with CONFIG_LOCK:
        config = load_config()
        idx, device = _find_device(config, device_name)
        if device is None:
            return jsonify({"error": f"Device '{device_name}' not found"}), 404

        calc_tags = device.get("calculatedTags", [])
        for ct in calc_tags:
            if ct["alias"] == alias:
                ct["formula"] = data["formula"]
                device["calculatedTags"] = calc_tags
                config["devices"][idx] = device
                save_config(config)
                return jsonify({"message": f"Calculated tag '{alias}' updated"})

    return jsonify({"error": f"Calculated tag '{alias}' not found"}), 404


@app.route("/api/devices/<device_name>/calculated/<alias>", methods=["DELETE"])
@require_admin
def api_delete_calculated_tag(device_name, alias):
    """Removes a calculated tag from a device."""
    with CONFIG_LOCK:
        config = load_config()
        idx, device = _find_device(config, device_name)
        if device is None:
            return jsonify({"error": f"Device '{device_name}' not found"}), 404

        calc_tags = device.get("calculatedTags", [])
        original_len = len(calc_tags)
        calc_tags = [t for t in calc_tags if t["alias"] != alias]
        if len(calc_tags) == original_len:
            return jsonify({"error": f"Calculated tag '{alias}' not found"}), 404

        device["calculatedTags"] = calc_tags
        config["devices"][idx] = device
        save_config(config)

    return jsonify({"message": f"Calculated tag '{alias}' removed"})


@app.route("/api/formula/validate", methods=["POST"])
def api_validate_formula():
    """Validates a formula and optionally evaluates it with test values."""
    data = request.get_json()
    if not data or "formula" not in data:
        return jsonify({"error": "Field 'formula' is required"}), 400

    formula = data["formula"]
    test_values = data.get("testValues", {})

    try:
        ast.parse(formula, mode="eval")
    except SyntaxError as e:
        return jsonify({"valid": False, "error": f"Syntax error: {e.msg}"}), 200

    if test_values:
        result, error = evaluate_formula(formula, test_values)
        return jsonify({"valid": True, "result": result, "error": error})

    return jsonify({"valid": True})


@app.route("/api/demo/load", methods=["POST"])
@require_admin
def api_load_demo_devices():
    """Loads pre-configured demo/test devices from demo-devices.json."""
    import json
    demo_path = os.path.join(os.path.dirname(CONFIG_PATH), "demo-devices.json")
    # Also check the app directory
    if not os.path.exists(demo_path):
        demo_path = "/app/demo-devices.json"
    if not os.path.exists(demo_path):
        return jsonify({"error": "Demo devices file not found"}), 404

    with open(demo_path, "r", encoding="utf-8") as f:
        demo_devices = json.load(f)

    with CONFIG_LOCK:
        config = load_config()
        existing_names = {d["name"] for d in config.get("devices", [])}
        added = []
        skipped = []

        for demo in demo_devices:
            if demo["name"] in existing_names:
                skipped.append(demo["name"])
            else:
                config.setdefault("devices", []).append(demo)
                existing_names.add(demo["name"])
                added.append(demo["name"])

        if added:
            save_config(config)

    return jsonify({
        "message": f"Added {len(added)} demo devices, skipped {len(skipped)} (already exist)",
        "added": added,
        "skipped": skipped
    })


# =============================================
# Routes - REST API: Users
# =============================================

@app.route("/api/users", methods=["GET"])
@require_admin
def api_list_users():
    """Lists all OPC-UA users (without password hashes)."""
    pwd_config = load_password_config()
    if not pwd_config or "users" not in pwd_config:
        return jsonify([])
    users = []
    for username, user_data in pwd_config["users"].items():
        users.append({
            "username": username,
            "security": user_data.get("security", ""),
            "hasPassword": bool(user_data.get("password"))
        })
    return jsonify(users)


@app.route("/api/users", methods=["POST"])
@require_admin
def api_add_user():
    """Adds a new OPC-UA user."""
    data = request.get_json()
    if not data or "username" not in data or "password" not in data:
        return jsonify({"error": "Fields 'username' and 'password' are required"}), 400

    username = data["username"].strip()
    password = data["password"]
    security = data.get("security", "admin-group")

    if not username:
        return jsonify({"error": "Username cannot be empty"}), 400
    if not password:
        return jsonify({"error": "Password cannot be empty"}), 400

    if not validate_name(username):
        return jsonify({"error": "Invalid username. Use only letters, numbers, dots, hyphens, underscores (max 128 chars)"}), 400

    with PASSWORD_LOCK:
        pwd_config = load_password_config()
        if not pwd_config:
            return jsonify({"error": "Security not initialized. Start the server first."}), 503

        if username in pwd_config.get("users", {}):
            return jsonify({"error": f"User '{username}' already exists"}), 409

        hash_hex, salt_b64, salt_bytes = hash_password(password)

        if "users" not in pwd_config:
            pwd_config["users"] = {}

        pwd_config["users"][username] = {
            "username": username,
            "password": hash_hex,
            "security": security,
            "salt": list(salt_bytes)
        }

        save_password_config(pwd_config)
    return jsonify({"message": f"User '{username}' added"}), 201


@app.route("/api/users/<username>", methods=["PUT"])
@require_admin
def api_update_user(username):
    """Updates an existing OPC-UA user (password and/or security group)."""
    data = request.get_json()
    if not data:
        return jsonify({"error": "Missing JSON body"}), 400
    with PASSWORD_LOCK:
        pwd_config = load_password_config()
        if not pwd_config or username not in pwd_config.get("users", {}):
            return jsonify({"error": f"User '{username}' not found"}), 404

        user = pwd_config["users"][username]
        if "security" in data:
            user["security"] = data["security"]
        if "password" in data and data["password"]:
            hash_hex, salt_b64, salt_bytes = hash_password(data["password"])
            user["password"] = hash_hex
            user["salt"] = list(salt_bytes)

        pwd_config["users"][username] = user
        save_password_config(pwd_config)
    return jsonify({"message": f"User '{username}' updated"})


@app.route("/api/users/<username>", methods=["DELETE"])
@require_admin
def api_delete_user(username):
    """Removes an OPC-UA user."""
    if username == ADMIN_USERNAME:
        return jsonify({"error": "Cannot delete the default admin user"}), 403
    with PASSWORD_LOCK:
        pwd_config = load_password_config()
        if not pwd_config or username not in pwd_config.get("users", {}):
            return jsonify({"error": f"User '{username}' not found"}), 404

        del pwd_config["users"][username]
        save_password_config(pwd_config)
    return jsonify({"message": f"User '{username}' removed"})


