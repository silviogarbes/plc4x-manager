@app.route("/api/config", methods=["GET"])
def api_get_config():
    """Returns the current configuration."""
    return jsonify(load_config())


@app.route("/api/config", methods=["PUT"])
@require_admin
def api_save_config():
    """Saves the complete configuration."""
    config = request.get_json()
    if not config:
        return jsonify({"error": "Empty payload"}), 400
    # Validate required config structure
    if not isinstance(config.get("devices"), list):
        return jsonify({"error": "Invalid config: 'devices' must be a list"}), 400
    if "name" not in config or "tcpPort" not in config:
        return jsonify({"error": "Invalid config: 'name' and 'tcpPort' are required"}), 400
    all_errors = []
    for dev in config.get("devices", []):
        if not isinstance(dev, dict) or "name" not in dev or "connectionString" not in dev:
            return jsonify({"error": "Invalid config: each device must have 'name' and 'connectionString'"}), 400
        tag_errors = validate_device_tags(dev)
        if tag_errors:
            all_errors.extend([f"{dev['name']}: {e}" for e in tag_errors])
    if all_errors:
        return jsonify({"error": "Invalid tag addresses: " + "; ".join(all_errors[:5])}), 400
    with CONFIG_LOCK:
        save_config(config)
    return jsonify({"message": "Configuration saved successfully"})


@app.route("/api/config/server", methods=["PUT"])
@require_admin
def api_update_server_config():
    """Updates the OPC-UA server settings (all config.yml fields)."""
    data = request.get_json()
    if not data:
        return jsonify({"error": "Missing JSON body"}), 400
    with CONFIG_LOCK:
        config = load_config()
        for key in ["version", "name", "tcpPort", "disableInsecureEndpoint", "dir"]:
            if key in data:
                config[key] = data[key]
        save_config(config)
    return jsonify({"message": "Server configuration updated"})


