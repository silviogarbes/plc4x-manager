# ===========================================
# PLC4X Manager - Version Configuration
# ===========================================
# To update PLC4X, just change the version here
# and run: docker compose build
PLC4X_VERSION=0.13.1

# OPC-UA server port
OPCUA_PORT=12687

# Web admin panel port
ADMIN_PORT=3080

# Web admin HTTPS port
ADMIN_HTTPS_PORT=3443

# ===========================================
# Authentication (CHANGE IN PRODUCTION!)
# ===========================================
# Admin credentials for the web panel and API
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# JWT secret key — MUST be set to a strong random value in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# If left empty, a random key is generated at startup (sessions lost on restart).
JWT_SECRET=dev-default-change-in-production

# JWT token expiry in hours
JWT_EXPIRY_HOURS=24

# API key for machine-to-machine access (leave empty to disable)
# External systems can use: curl -H "X-API-Key: <key>" http://host:8080/api/...
API_KEY=

# Global read-only mode — blocks ALL writes to ALL PLCs
# Set to "true" to make the entire system read-only (monitoring only, no PLC writes)
# Useful for: initial deployment testing, audit periods, maintenance windows
PLC_READONLY=false

# MQTT credentials
MQTT_USERNAME=plc4x
MQTT_PASSWORD=plc4x

# InfluxDB credentials and settings
INFLUXDB_ADMIN_PASSWORD=plc4x-admin
INFLUXDB_TOKEN=plc4x-token
INFLUXDB_ORG=plc4x
INFLUXDB_BUCKET=plc4x_raw
INFLUXDB_RETENTION_DAYS=90
INFLUXDB_PORT=8086

# Grafana settings
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_PORT=3000
